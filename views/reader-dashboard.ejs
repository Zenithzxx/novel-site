<%- include('partials/header') %>

<main class="library-hero">
    <h1>Discover Masterpieces</h1>
    <p style="color: var(--text-muted); margin-top: 0.5rem;">Immerse yourself in high-quality typography-first narrative structures.</p>

    <div class="search-filter-bar">
        <form class="search-wrapper" action="/" method="GET">
            <input type="text" name="search" placeholder="Search title..." value="<%= search %>">
        </form>
        <div class="filter-pills">
            <a href="/?genre=" class="pill <%= !genreFilter ? 'active' : '' ?>">All Genres</a>
            <a href="/?genre=Fantasy" class="pill <%= genreFilter === 'Fantasy' ? 'active' : '' ?>">Fantasy</a>
            <a href="/?genre=Sci-Fi" class="pill <%= genreFilter === 'Sci-Fi' ? 'active' : '' ?>">Sci-Fi</a>
            <a href="/?genre=Romance" class="pill <%= genreFilter === 'Romance' ? 'active' : '' ?>">Romance</a>
            <a href="/?genre=Mystery" class="pill <%= genreFilter === 'Mystery' ? 'active' : '' ?>">Mystery</a>
        </div>
    </div>
</main>

<section class="novel-grid">
    <% if (novels.length === 0) { %>
        <p>No novels found.</p>
    <% } else { %>
        <% novels.forEach(novel => { %>
            <article class="novel-card" onclick="window.location.href='/novel/<%= novel.id %>'">
                <div class="novel-cover-fallback" style="background: linear-gradient(135deg, #2c3e50 0%, #0f172a 100%)">
                    <div class="cover-title"><%= novel.title %></div>
                </div>
                <div class="novel-info">
                    <h3 class="novel-title"><%= novel.title %></h3>
                    <p class="novel-meta"><%= novel.genre %> &bull; <%= novel.description.substring(0, 40) %>...</p>
                </div>
            </article>
        <% }) %>
    <% } %>
</section>

<% if (totalPages > 1) { %>
    <div style="display: flex; justify-content: center; gap: 10px; margin-bottom: 40px;">
        <% if (currentPage > 1) { %>
            <a href="/?page=<%= currentPage - 1 %>&search=<%= search %>&genre=<%= genreFilter %>" class="btn-nav">Prev</a>
        <% } %>
        <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/?page=<%= i %>&search=<%= search %>&genre=<%= genreFilter %>" class="btn-nav" style="<%= i === currentPage ? 'background: var(--accent); color: white;' : '' %>"><%= i %></a>
        <% } %>
        <% if (currentPage < totalPages) { %>
            <a href="/?page=<%= currentPage + 1 %>&search=<%= search %>&genre=<%= genreFilter %>" class="btn-nav">Next</a>
        <% } %>
    </div>
<% } %>

<%- include('partials/footer') %>