<%- include('partials/header') %>
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

<h2><%= chapter ? 'Edit Chapter' : 'Add New Chapter' %> (<%= novel.title %>)</h2>
<form action="<%= action %>" method="POST">
    <input type="text" name="title" placeholder="Chapter Title" value="<%= chapter ? chapter.title : '' %>" required>
    
    <div style="margin: 20px 0; display: flex; align-items: center; gap: 8px;">
        <input type="checkbox" id="publish_now" name="publish_now" style="width: auto; margin: 0;"
            <%= chapter && new Date(chapter.publish_date) <= new Date() ? 'checked' : '' %> 
            onchange="toggleSchedule()">
        <label for="publish_now" style="margin: 0;">Publish immediately</label>
    </div>

    <div id="schedule-box" style="margin-bottom: 15px; display: none;">
        <label>Schedule Publish Date:</label>
        <input type="datetime-local" name="publish_date" value="<%= chapter ? new Date(chapter.publish_date).toISOString().slice(0,16) : '' %>">
    </div>

    <div id="editor" style="margin-bottom: 15px;"><%- chapter ? chapter.content : '' %></div>
    <input type="hidden" name="content" id="content-input">
    <button type="submit" id="save-btn">Save Chapter</button>
</form>

<script>
    var quill = new Quill('#editor', { theme: 'snow' });
    document.getElementById('save-btn').addEventListener('click', function() {
        document.getElementById('content-input').value = quill.root.innerHTML;
    });

    function toggleSchedule() {
        var checkbox = document.getElementById('publish_now');
        var scheduleBox = document.getElementById('schedule-box');
        if (checkbox.checked) {
            scheduleBox.style.display = 'none';
        } else {
            scheduleBox.style.display = 'block';
        }
    }
    // Run on load to set initial state
    toggleSchedule();
</script>
<%- include('partials/footer') %>