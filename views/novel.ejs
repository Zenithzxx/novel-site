<%- include('partials/header') %>

<section class="synopsis-hero">
    <div class="synopsis-container">
        <div class="novel-cover-fallback" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); height: 380px;">
            <div class="cover-title" style="font-size: 1.75rem;"><%= novel.title %></div>
        </div>
        
        <div class="synopsis-details">
            <span class="synopsis-meta"><%= novel.genre %> &bull; Premium Collection</span>
            <h1 class="synopsis-title"><%= novel.title %></h1>
            <p style="color: var(--text-muted); font-weight: 500; margin-bottom: 1.5rem;">By <%= user ? user.username : 'Author' %></p>
            <p class="synopsis-text">
                <%= novel.description %>
            </p>
            <% if (chapters.length > 0) { %>
                <button class="btn-primary" onclick="window.location.href='/novel/<%= novel.id %>/chapter/<%= chapters[0].id %>'">Start Reading</button>
            <% } else { %>
                <p style="color: var(--text-muted);">No chapters published yet.</p>
            <% } %>
        </div>
    </div>
</section>

<main class="toc-section">
    <h2 class="section-heading">Table of Contents</h2>
    <ul class="toc-list">
        <% chapters.forEach((chapter, index) => { %>
            <li class="toc-item">
                <a href="/novel/<%= novel.id %>/chapter/<%= chapter.id %>">
                    <span>Chapter <%= index + 1 %>: <%= chapter.title %></span>
                    <% if (readChapters.includes(chapter.id)) { %>
                        <span class="status-icon read" aria-label="Completed Chapter"></span>
                    <% } %>
                </a>
            </li>
        <% }) %>
    </ul>
</main>

<%- include('partials/footer') %>