<%- include('partials/header') %>

<div class="reader-workspace" id="readerWorkspace" data-reader-theme="light">
    
    <nav class="reader-settings-bar">
        <div class="settings-container">
            <div class="setting-group">
                <button class="setting-btn" id="fontDecrease" aria-label="Decrease Font Size">A-</button>
                <button class="setting-btn" id="fontIncrease" aria-label="Increase Font Size">A+</button>
            </div>
            <div class="setting-group">
                <div class="theme-swatch swatch-light" data-theme-target="light" title="Light Theme"></div>
                <div class="theme-swatch swatch-sepia" data-theme-target="sepia" title="Warm Sepia Theme"></div>
                <div class="theme-swatch swatch-dark" data-theme-target="dark" title="Deep Charcoal Theme"></div>
            </div>
        </div>
    </nav>

    <main class="reader-container">
        <header class="chapter-header">
            <div class="chapter-meta">Chapter</div>
            <h1 class="chapter-title"><%= chapter.title %></h1>
        </header>

        <article class="reading-content" id="readingTextBody">
            <%- chapter.content %>
        </article>

        <nav class="reader-navigation">
            <% if (prevChapter) { %>
                <button class="btn-nav" onclick="window.location.href='/novel/<%= novelId %>/chapter/<%= prevChapter.id %>'">Previous Chapter</button>
            <% } else { %>
                <div></div> 
            <% } %>
            
            <% if (nextChapter) { %>
                <button class="btn-nav" onclick="window.location.href='/novel/<%= novelId %>/chapter/<%= nextChapter.id %>'">Next Chapter</button>
            <% } else { %>
                <button class="btn-nav" onclick="window.location.href='/novel/<%= novelId %>'">Return to Synopsis</button>
            <% } %>
        </nav>
    </main>

    <section class="comments-section">
        <h2 class="section-heading">Discussion (<%= comments.length %>)</h2>
        
        <form class="comment-form" action="/novel/<%= novelId %>/chapter/<%= chapter.id %>/comment" method="POST">
            <textarea name="comment" placeholder="Join the discussion, share theories..." required></textarea>
            <button type="submit" class="btn-primary" style="padding: 0.65rem 1.75rem; font-size: 0.9rem;">Post Comment</button>
        </form>

        <div class="comment-thread">
            <% comments.forEach(comment => { %>
                <div class="comment-card">
                    <div class="avatar-fallback">
                        <%= comment.username.charAt(0).toUpperCase() %>
                    </div>
                    <div class="comment-content">
                        <div class="comment-header">
                            <span class="comment-author"><%= comment.username %></span>
                            <% if(comment.title) { %>
                                <span class="badge"><%= comment.title %></span>
                            <% } %>
                            <span class="comment-time">&bull; <%= new Date(comment.created_at).toLocaleString() %></span>
                        </div>
                        <p class="comment-body"><%= comment.comment %></p>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const workspace = document.getElementById('readerWorkspace');
        const textBody = document.getElementById('readingTextBody');
        
        let currentFontSize = parseFloat(localStorage.getItem('reader-font-scale')) || 1.15;
        let activeReaderTheme = localStorage.getItem('reader-theme-state') || 'light';
        
        textBody.style.setProperty('--reader-font-size', `${currentFontSize}rem`);
        workspace.setAttribute('data-reader-theme', activeReaderTheme);

        document.getElementById('fontIncrease').addEventListener('click', () => {
            if(currentFontSize < 1.7) {
                currentFontSize += 0.05;
                textBody.style.setProperty('--reader-font-size', `${currentFontSize}rem`);
                localStorage.setItem('reader-font-scale', currentFontSize);
            }
        });

        document.getElementById('fontDecrease').addEventListener('click', () => {
            if(currentFontSize > 0.9) {
                currentFontSize -= 0.05;
                textBody.style.setProperty('--reader-font-size', `${currentFontSize}rem`);
                localStorage.setItem('reader-font-scale', currentFontSize);
            }
        });

        document.querySelectorAll('.theme-swatch').forEach(swatch => {
            swatch.addEventListener('click', (e) => {
                const selectedTheme = e.target.getAttribute('data-theme-target');
                workspace.setAttribute('data-reader-theme', selectedTheme);
                localStorage.setItem('reader-theme-state', selectedTheme);
            });
        });
    });
</script>

<%- include('partials/footer') %>