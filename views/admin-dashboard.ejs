<%- include('partials/header') %>

<h2>Admin Dashboard</h2>
<div class="stats-grid">
    <div class="stat-card">
        <h3>Total Views</h3>
        <p><%= totalViews %></p>
    </div>
    <div class="stat-card">
        <h3>Total Novels</h3>
        <p><%= novels.length %></p>
    </div>
</div>
<p>Welcome, <%= user.username %>! You can manage your novels here.</p>
<a href="/novels/new" class="btn">+ Post New Novel</a>

<table class="novel-table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% novels.forEach(function(novel) { %>
            <tr>
                <td><%= novel.title %></td>
                <td><%= novel.description.substring(0, 50) %>...</td>
                <td>
                    <a href="/admin/novel/<%= novel.id %>/chapters" class="btn-sm">Chapters</a>
                    <a href="/novels/<%= novel.id %>/edit" class="btn-sm">Edit</a>
                    <form action="/novels/<%= novel.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure?');">
                        <button type="submit" class="btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        <% }) %>
    </tbody>
</table>

<%- include('partials/footer') %>