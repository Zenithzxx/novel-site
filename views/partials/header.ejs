<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Novel Pub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script>
        if (localStorage.getItem('darkMode') === 'enabled') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
</head>
<body>
    <!-- Sticky Reading Progress Bar -->
    <div class="progress-container">
        <div class="progress-bar" id="myBar"></div>
    </div>

    <nav class="main-nav">
        <h1><a href="/">NovelPub</a></h1>
        <div class="nav-links">
            <a href="#" id="dark-mode-toggle">🌙</a>
            <% if (user) { %>
                <a href="/notifications" style="position: relative;">🔔
                    <% if (locals.unreadNotifications > 0) { %>
                        <span class="notif-badge"><%= unreadNotifications %></span>
                    <% } %>
                </a>
                <a href="/my-library">Library</a>
                <a href="/profile">Profile</a>
                <% if (user.role === 'admin') { %>
                    <a href="/admin-dashboard" class="admin-btn">Admin</a>
                <% } %>
                <a href="/logout">Logout</a>
            <% } else { %>
                <a href="/login">Login</a>
                <a href="/register">Register</a>
            <% } %>
        </div>
    </nav>
    <main class="container">