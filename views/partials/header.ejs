<!DOCTYPE html>
<html lang="en" data-theme="global-light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Ink & Quill | Premium Publishing' %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
    <!-- Prevent flash of white screen before dark mode loads -->
    <script>
        const cachedTheme = localStorage.getItem('global-theme') || 'global-light';
        document.documentElement.setAttribute('data-theme', cachedTheme);
    </script>
</head>
<body>

    <div class="progress-container">
        <div class="progress-bar" id="readingProgress"></div>
    </div>

    <header class="site-header">
        <div class="header-container">
            <a href="/" class="logo">Ink & Quill</a>
            
            <nav class="nav-menu" id="navMenu">
                <a href="/" class="nav-link">Library</a>
                <a href="/my-library" class="nav-link">My Library</a>
                <button class="theme-toggle-btn" id="globalThemeToggle" aria-label="Toggle Night Mode">Theme</button>
                
                <% if (user) { %>
                    <a href="/notifications" class="nav-link" style="position: relative;">🔔
                        <% if (locals.unreadNotifications > 0) { %>
                            <span style="background: red; color: white; border-radius: 50%; padding: 1px 5px; font-size: 10px; position: absolute; top: -5px; right: -8px;"><%= unreadNotifications %></span>
                        <% } %>
                    </a>
                    <a href="/profile" class="nav-link">Profile</a>
                    <% if (user.role === 'admin') { %>
                        <a href="/admin-dashboard" class="nav-link" style="background: #e67e22; padding: 5px 10px; border-radius: 4px; color: white;">Admin</a>
                    <% } %>
                    <a href="/logout" class="nav-link">Logout</a>
                <% } else { %>
                    <a href="/login" class="nav-link">Login</a>
                    <a href="/register" class="nav-link">Register</a>
                <% } %>
            </nav>

            <div class="hamburger" id="hamburgerMenu">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </header>